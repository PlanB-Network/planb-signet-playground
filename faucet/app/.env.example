# Flask
FLASK_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
# Set to true only for throwaway local development without a secret.
ALLOW_INSECURE_DEV_SECRET=false

# Storage/logs
DB_PATH=./faucet.db
LOG_DIR=./logs

# Bitcoin Core RPC (Signet)
RPC_USER=devuser
RPC_PASSWORD=devpass123
RPC_HOST=127.0.0.1
RPC_PORT=38332
RPC_WALLET=test-wallet
BTC_AMOUNT=0.001
EXPLORER_URL=https://mempool-signet.planb.academy

# Anti-abuse
RATE_LIMIT_HOURS=24
BTC_DAILY_LIMIT_SATS=1000000
LN_DAILY_LIMIT_SATS=100000

# Lightning via lncli (temporary until Squad 3 LNbits contract is wired)
LN_MAX_SATS=10000
LNCLI_BIN=lncli
LND_DIR=/var/lib/lnd-signet
LND_RPCSERVER=127.0.0.1:10010
