# Quiz server config — copy to .env and fill in.

# Port the Express server binds to.
PORT=3000

# Where the SQLite winners log lives. Use an absolute path on the VPS so the
# DB survives a reinstall (e.g. /var/lib/planb-quiz/winners_log.db).
DB_PATH=./winners_log.db

# LNbits instance run by Squad 3 — see infrastructure/lnbits/README.md.
# Local dev: http://localhost:5000
# Production: https://lnbits-signet.planb.academy (or whatever Squad 3 publishes)
LNBITS_URL=http://localhost:5000

# Admin key of the "Big Pot" wallet that funds quiz rewards. NEVER commit
# the real value — get it from the LNbits admin UI ("API info" on the wallet).
LNBITS_ADMIN_KEY=replace-me
