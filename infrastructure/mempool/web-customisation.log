# Frontend customisation — step-by-step runbook
# Target: flagrant-feedback, user install, ~/mempool-space (v3.3.1)
# Prerequisites: repo cloned, db + api containers running, stack serving on :8080

# ─────────────────────────────────────────────────────────────────────────────
# STEP 1 — Fix repo-level nginx/Docker bugs in v3.3.1
# (only needed on a fresh clone; already applied on flagrant-feedback)
# ─────────────────────────────────────────────────────────────────────────────

# 1a. nginx.conf: fix listen port (hardcoded 127.0.0.1:80 → template var)
sed -i 's|listen 127.0.0.1:80;|listen __MEMPOOL_FRONTEND_HTTP_PORT__;|' \
  ~/mempool-space/nginx.conf

# 1b. nginx.conf: fix include path (wrong location → conf.d where file lives)
sed -i 's|include /etc/nginx/nginx-mempool.conf;|include /etc/nginx/conf.d/nginx-mempool.conf;|' \
  ~/mempool-space/nginx.conf

# 1c. nginx-mempool.conf: replace hardcoded 127.0.0.1:8999 with template vars
#     (127.0.0.1 is localhost *inside* the web container — unreachable;
#      entrypoint.sh substitutes the api container hostname at runtime)
sed -i \
  's|http://127.0.0.1:8999/|http://__MEMPOOL_BACKEND_MAINNET_HTTP_HOST__:__MEMPOOL_BACKEND_MAINNET_HTTP_PORT__/|g' \
  ~/mempool-space/nginx-mempool.conf
sed -i \
  's|http://127.0.0.1:8999/api/v1|http://__MEMPOOL_BACKEND_MAINNET_HTTP_HOST__:__MEMPOOL_BACKEND_MAINNET_HTTP_PORT__/api/v1|g' \
  ~/mempool-space/nginx-mempool.conf

# 1d. entrypoint.sh: align sed paths with the conf.d location
sed -i \
  's|/etc/nginx/nginx-mempool.conf|/etc/nginx/conf.d/nginx-mempool.conf|g' \
  ~/mempool-space/docker/frontend/entrypoint.sh

# Verify
grep 'listen\|include /etc/nginx/conf' ~/mempool-space/nginx.conf | tail -3
# Expect:
#   listen __MEMPOOL_FRONTEND_HTTP_PORT__;
#   include /etc/nginx/conf.d/nginx-mempool.conf;

grep 'proxy_pass http' ~/mempool-space/nginx-mempool.conf
# Expect: all lines now contain __MEMPOOL_BACKEND_MAINNET_HTTP_HOST__

# ─────────────────────────────────────────────────────────────────────────────
# STEP 2 — Apply PlanB branding to the Angular frontend source
# ─────────────────────────────────────────────────────────────────────────────

# 2a. SVG logo
#     Replaces the mempoolSpace SVG variant (used on all non-official instances)
#     with a two-row layout: "mempool" (white, upper row) + "planb" (orange, lower row).
#     Covers all three logo locations: desktop navbar, mobile navbar, footer.

python3 << 'PYEOF'
