new_lines = lines[:121] + [new_svg] + lines[139:]

with open(SVG_FILE, 'w') as f:
    f.writelines(new_lines)

print(f"SVG done. Lines: {len(lines)} → {len(new_lines)}")
PYEOF
# Expect: SVG done. Lines: 802 → 785

# 2b. Footer tagline (3 instances: mobile, desktop, footer link)
python3 << 'PYEOF'
path = '/home/install/mempool-space/frontend/src/app/shared/components/global-footer/global-footer.component.html'
with open(path, 'r') as f:
    content = f.read()

# Mobile + desktop tagline instances (trade mark on next line)
old1 = '<ng-container i18n="shared.be-your-own-explorer">Be your own explorer</ng-container>\n              <ng-template [ngIf]="locale.substr(0, 2) === \'en\'\">&trade;</ng-template>'
new1 = '<ng-container i18n="shared.be-your-own-explorer">PlanB Network signet playground</ng-container>'
result = content.replace(old1, new1)

# Footer link instance (trade mark inline)
old2 = '<ng-container i18n="shared.be-your-own-explorer">Be your own explorer</ng-container><ng-template [ngIf]="locale.substr(0, 2) === \'en\'\">&trade;</ng-template>'
new2 = '<ng-container i18n="shared.be-your-own-explorer">PlanB Network signet playground</ng-container>'
result = result.replace(old2, new2)

replaced = content.count('Be your own explorer') - result.count('Be your own explorer')
print(f"Footer tagline: replaced {replaced}/3")

with open(path, 'w') as f:
    f.write(result)
PYEOF
# Expect: Footer tagline: replaced 3/3

# 2c. About page heading (1 instance)
python3 << 'PYEOF'
path = '/home/install/mempool-space/frontend/src/app/components/about/about.component.html'
with open(path, 'r') as f:
    content = f.read()

old = '<ng-container i18n="shared.be-your-own-explorer">Be your own explorer</ng-container><ng-template [ngIf]="locale.substr(0, 2) === \'en\'\">&trade;</ng-template>'
new = '<ng-container i18n="shared.be-your-own-explorer">PlanB Network signet playground</ng-container>'
result = content.replace(old, new)

replaced = content.count('Be your own explorer') - result.count('Be your own explorer')
print(f"About heading: replaced {replaced}/1 (1 remaining = legal text, leave it)")

with open(path, 'w') as f:
    f.write(result)
PYEOF
# Expect: About heading: replaced 1/1 (1 remaining = legal text, leave it)

# 2d. Browser tab title
sed -i \
  's|<title>mempool - Bitcoin Explorer</title>|<title>mempool Planb signet</title>|' \
  ~/mempool-space/frontend/src/index.mempool.html

grep '<title>' ~/mempool-space/frontend/src/index.mempool.html
# Expect: <title>mempool Planb signet</title>

# ─────────────────────────────────────────────────────────────────────────────
# STEP 3 — Stage auxiliary files into the frontend/ build context
# (these files live elsewhere in the repo but must be present for docker build)
# ─────────────────────────────────────────────────────────────────────────────

cp ~/mempool-space/docker/frontend/entrypoint.sh ~/mempool-space/frontend/
cp ~/mempool-space/docker/frontend/wait-for       ~/mempool-space/frontend/
cp ~/mempool-space/nginx.conf                     ~/mempool-space/frontend/
cp ~/mempool-space/nginx-mempool.conf             ~/mempool-space/frontend/

# ─────────────────────────────────────────────────────────────────────────────
# STEP 4 — Build the custom Docker image
# (Node/Angular build stage takes ~5 min; nginx stage is fast)
# ─────────────────────────────────────────────────────────────────────────────

cd ~/mempool-space
docker build -t planb-mempool-frontend:latest \
  -f docker/frontend/Dockerfile frontend/

# Expect last line: Successfully tagged planb-mempool-frontend:latest

# ─────────────────────────────────────────────────────────────────────────────
# STEP 5 — Point docker-compose.yml at the custom image
# ─────────────────────────────────────────────────────────────────────────────

sed -i \
  's|image: mempool/frontend:latest|image: planb-mempool-frontend:latest|' \
  ~/mempool-space/docker-compose.yml

grep 'image:' ~/mempool-space/docker-compose.yml
# Expect: image: planb-mempool-frontend:latest   (web service)
#         image: mempool/backend:latest            (api — unchanged)
#         image: mariadb:10.5.21                   (db  — unchanged)

# ─────────────────────────────────────────────────────────────────────────────
# STEP 6 — Deploy
# ─────────────────────────────────────────────────────────────────────────────

docker compose -f ~/mempool-space/docker-compose.yml up -d --no-deps web

# ─────────────────────────────────────────────────────────────────────────────
# STEP 7 — Verify
# ─────────────────────────────────────────────────────────────────────────────

sleep 8
docker ps --filter name=web
# Expect: Up X seconds   0.0.0.0:8080->8080/tcp   (no "Restarting")

curl -s http://127.0.0.1:8080/ | grep '<title>'
# Expect: <title>mempool Planb signet</title>

docker logs mempool-space-web-1 2>&1 | grep -v warn
# Expect: no [emerg] or [error] lines

# Open http://<host-ip>:8080 in a browser and confirm:
#   - Logo top-left: "mempool" (white) above "planb" (orange)
#   - Footer logo: same
#   - Footer tagline: "PlanB Network signet playground"
#   - Browser tab: "mempool Planb signet"
