with open(SVG_FILE, 'r') as f:
    lines = f.readlines()

assert lines[120].strip().startswith("<ng-container *ngSwitchCase=\"'mempoolSpace'\""), \
    f"Unexpected content at line 121: {lines[120]}"
assert lines[140].strip().startswith("<ng-container *ngSwitchCase=\"'mempoolSquare'\""), \
    f"Unexpected content at line 141: {lines[140]}"

