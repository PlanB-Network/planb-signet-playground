# Mempool install session log — 2026-04-29
# Machine: flagrant-feedback (Linux 6.8.0-110-generic, user: install)

## 1. Start bitcoind on custom signet

bitcoind -signet -daemon
sleep 3 && bitcoin-cli -signet getblockchaininfo
# Result: chain=signet, blocks=131, custom signetchallenge confirmed

## 2. Install Docker Engine + Compose v2

sudo apt-get update -qq && sudo apt-get install -y -qq docker.io docker-compose-v2
sudo usermod -aG docker install
# Verified with: sg docker -c "docker ps"
# Docker version 29.1.3, Docker Compose version 2.40.3

## 3. Clone upstream mempool repo

# ~/mempool was already taken (monorepo parent), used ~/mempool-space instead
sg docker -c "git clone https://github.com/mempool/mempool.git ~/mempool-space"
cd ~/mempool-space && git checkout v3.3.1
mkdir -p ~/mempool-space/mysql/data ~/mempool-space/data

## 4. Open bitcoind RPC + ZMQ to Docker bridge

# Edited ~/.bitcoin/bitcoin.conf:
#   - Changed zmqpubrawblock and zmqpubrawtx from 127.0.0.1 to 0.0.0.0
#   - Added rpcbind=0.0.0.0
#   - Added rpcallowip=127.0.0.1
#   - Added rpcallowip=172.16.0.0/12

# Restarted bitcoind:
bitcoin-cli -signet stop
sleep 3
bitcoind -signet -daemon
bitcoin-cli -signet getblockcount
# Result: 131

## 5. Created docker-compose.yml at ~/mempool-space/docker-compose.yml

# Key settings:
#   - MEMPOOL_NETWORK=signet, MEMPOOL_BACKEND=none (no electrs)
#   - CORE_RPC_HOST=host.docker.internal, CORE_RPC_PORT=38332
#   - CORE_RPC_USERNAME=devuser, CORE_RPC_PASSWORD=devpass123
#   - Using stock mempool/frontend:latest (no customization yet)
#   - Ports: 127.0.0.1:8080:8080 (loopback only)
#   - MariaDB: mariadb:10.5.21, user 1000:1000

## 6. Brought up the stack

sg docker -c "docker compose -f ~/mempool-space/docker-compose.yml up -d db"
sleep 10 && sg docker -c "docker inspect -f '{{.State.Health.Status}}' mempool-space-db-1"
# Result: healthy

sg docker -c "docker compose -f ~/mempool-space/docker-compose.yml up -d api"
sleep 15 && sg docker -c "docker compose -f ~/mempool-space/docker-compose.yml logs --tail=30 api"
# Result: "The mempool is now in sync!", block indexing completed (xxx blocks)

sg docker -c "docker compose -f ~/mempool-space/docker-compose.yml up -d web"
# Result: Container mempool-space-web-1 started

## 7. Validation

sg docker -c "docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'"
# All 3 containers running:
#   mempool-space-web-1   Up   127.0.0.1:8080->8080/tcp
#   mempool-space-api-1   Up   8999/tcp
#   mempool-space-db-1    Up   (healthy) 3306/tcp

curl -s http://127.0.0.1:8080/api/v1/blocks/tip/height
# Result: 131

bitcoin-cli -signet getblockcount
# Result: 131
# Tip heights match.

curl -s http://127.0.0.1:8080/ | head -5
# Result: serves HTML (<!doctype html>)

# RPC reachable from inside a container via Docker bridge:
sg docker -c "docker run --rm --add-host=host.docker.internal:host-gateway curlimages/curl:latest -s --user devuser:devpass123 --data-binary '{\"jsonrpc\":\"1.0\",\"id\":\"t\",\"method\":\"getblockcount\",\"params\":[]}' -H 'content-type: text/plain;' http://host.docker.internal:38332/"
# Result: {"result":131,"error":null,"id":"t"}

